        [ a ex:TurnOnCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home81/balcony/artifacts/balconyAromatherapy/turn_on> ] ;
            td:name "turnOn" ;
            td:title "turnOn" ] ;
    td:hasPropertyAffordance [ a td:PropertyAffordance ;
