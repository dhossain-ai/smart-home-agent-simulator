        <http://localhost:8080/workspaces/home40/kitchen#workspace>,
        <http://localhost:8080/workspaces/home40/living_room#workspace>,
        <http://localhost:8080/workspaces/home40/master_bedroom#workspace>,
        <http://localhost:8080/workspaces/home40/store_room#workspace>,
        <http://localhost:8080/workspaces/home40/study_room#workspace> ;
    td:title "Home 40" .

<http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy#artifact> a ex:Aromatherapy,
        hmas:Artifact,
        td:Thing ;
    hmas:isContainedIn <http://localhost:8080/workspaces/home40/balcony#workspace> ;
    td:hasActionAffordance [ a ex:SetIntervalCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/set_interval> ] ;
            td:hasInputSchema [ a jsonschema:ObjectSchema ;
                    jsonschema:properties [ a jsonschema:IntegerSchema ;
                            jsonschema:maximum "60" ;
                            jsonschema:minimum "10" ;
                            jsonschema:propertyName "interval" ] ;
                    jsonschema:required "interval" ] ;
            td:name "setInterval" ;
            td:title "setInterval" ],
        [ a ex:TurnOnCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/turn_on> ] ;
            td:name "turnOn" ;
            td:title "turnOn" ],
        [ a ex:TurnOffCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/turn_off> ] ;
            td:name "turnOff" ;
            td:title "turnOff" ],
        [ a ex:SetIntensityCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/set_intensity> ] ;
            td:hasInputSchema [ a jsonschema:ObjectSchema ;
                    jsonschema:properties [ a jsonschema:IntegerSchema ;
                            jsonschema:maximum "100" ;
                            jsonschema:minimum "0" ;
                            jsonschema:propertyName "intensity" ] ;
                    jsonschema:required "intensity" ] ;
            td:name "setIntensity" ;
            td:title "setIntensity" ] ;
    td:hasPropertyAffordance [ a td:PropertyAffordance ;
            rdfs:comment "interval of balconyAromatherapy" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/properties/interval> ] ;
            td:hasOutputSchema [ a jsonschema:IntegerSchema ;
                    jsonschema:maximum "60" ;
                    jsonschema:minimum "10" ] ;
            td:isObservable true ;
            td:name "interval" ;
            td:title "interval" ],
        [ a td:PropertyAffordance ;
            rdfs:comment "intensity of balconyAromatherapy" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/properties/intensity> ] ;
            td:hasOutputSchema [ a jsonschema:IntegerSchema ;
                    jsonschema:maximum "100" ;
                    jsonschema:minimum "0" ] ;
            td:isObservable true ;
            td:name "intensity" ;
            td:title "intensity" ],
        [ a td:PropertyAffordance ;
            rdfs:comment "state of balconyAromatherapy" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home40/balcony/artifacts/balconyAromatherapy/properties/state> ] ;
            td:hasOutputSchema [ a jsonschema:StringSchema ;
                    jsonschema:enum "off",
                        "on" ] ;
            td:isObservable true ;
            td:name "state" ;
            td:title "state" ] ;
    td:title "Balconyaromatherapy" .

