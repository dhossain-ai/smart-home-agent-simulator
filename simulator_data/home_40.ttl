<http://localhost:8080/workspaces/home40#workspace> a ex:Home,
        hmas:Workspace,
        td:Thing ;
    hmas:contains <http://localhost:8080/workspaces/home40/balcony#workspace>,
        <http://localhost:8080/workspaces/home40/bathroom#workspace>,
        <http://localhost:8080/workspaces/home40/corridor#workspace>,
        <http://localhost:8080/workspaces/home40/dining_room#workspace>,
        <http://localhost:8080/workspaces/home40/foyer#workspace>,
