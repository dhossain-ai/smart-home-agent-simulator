            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home57/balcony/artifacts/balconyLight/turn_on> ] ;
            td:name "turnOn" ;
            td:title "turnOn" ],
        [ a ex:SetBrightnessCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
