                            jsonschema:propertyName "color" ] ;
                    jsonschema:required "color" ] ;
            td:name "setColor" ;
            td:title "setColor" ],
        [ a ex:TurnOffCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
