<http://localhost:8080/workspaces/home57/balcony/artifacts/balconyLight#artifact> a ex:Light,
        hmas:Artifact,
        td:Thing ;
    hmas:isContainedIn <http://localhost:8080/workspaces/home57/balcony#workspace> ;
    td:hasActionAffordance [ a ex:TurnOnCommand,
