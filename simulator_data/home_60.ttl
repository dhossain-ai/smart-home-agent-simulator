        <http://localhost:8080/workspaces/home60/study_room#workspace> ;
    td:title "Home 60" .

<http://localhost:8080/workspaces/home60/balcony/artifacts/balconyLight#artifact> a ex:Light,
        hmas:Artifact,
        td:Thing ;
    hmas:isContainedIn <http://localhost:8080/workspaces/home60/balcony#workspace> ;
    td:hasActionAffordance [ a ex:TurnOffCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home60/balcony/artifacts/balconyLight/turn_off> ] ;
            td:name "turnOff" ;
            td:title "turnOff" ],
        [ a ex:SetBrightnessCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home60/balcony/artifacts/balconyLight/set_brightness> ] ;
            td:hasInputSchema [ a jsonschema:ObjectSchema ;
                    jsonschema:properties [ a jsonschema:IntegerSchema ;
                            jsonschema:maximum 100 ;
                            jsonschema:minimum 0 ;
                            jsonschema:propertyName "brightness" ] ;
                    jsonschema:required "brightness" ] ;
            td:name "setBrightness" ;
            td:title "setBrightness" ],
        [ a ex:TurnOnCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home60/balcony/artifacts/balconyLight/turn_on> ] ;
            td:name "turnOn" ;
            td:title "turnOn" ] ;
    td:hasPropertyAffordance [ a td:PropertyAffordance ;
            rdfs:comment "brightness of balconyLight" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home60/balcony/artifacts/balconyLight/properties/brightness> ] ;
            td:hasOutputSchema [ a jsonschema:IntegerSchema ;
                    jsonschema:maximum 100 ;
                    jsonschema:minimum 0 ] ;
            td:isObservable true ;
            td:name "brightness" ;
            td:title "brightness" ],
        [ a td:PropertyAffordance ;
            rdfs:comment "state of balconyLight" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home60/balcony/artifacts/balconyLight/properties/state> ] ;
            td:hasOutputSchema [ a jsonschema:StringSchema ;
                    jsonschema:enum "off",
                        "on" ] ;
            td:isObservable true ;
            td:name "state" ;
            td:title "state" ] ;
    td:title "Balconylight" .

