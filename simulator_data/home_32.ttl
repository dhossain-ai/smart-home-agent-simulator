                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home32/balcony/artifacts/balconyLight/turn_off> ] ;
            td:name "turnOff" ;
            td:title "turnOff" ],
        [ a ex:TurnOnCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home32/balcony/artifacts/balconyLight/turn_on> ] ;
            td:name "turnOn" ;
            td:title "turnOn" ],
        [ a ex:SetColorCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home32/balcony/artifacts/balconyLight/set_color> ] ;
            td:hasInputSchema [ a jsonschema:ObjectSchema ;
