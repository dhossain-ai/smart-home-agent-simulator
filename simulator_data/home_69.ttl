<http://localhost:8080/workspaces/home69/artifacts/vacuum_robot#artifact> a ex:VacuumRobot,
        hmas:Artifact,
        td:Thing ;
    hmas:isContainedIn <http://localhost:8080/workspaces/home69#workspace> ;
    td:hasActionAffordance [ a ex:SetModeCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home69/artifacts/vacuum_robot/set_mode> ] ;
            td:hasInputSchema [ a jsonschema:ObjectSchema ;
                    jsonschema:properties [ a jsonschema:StringSchema ;
                            jsonschema:enum "auto",
                                "sleep",
                                "strong" ;
                            jsonschema:propertyName "mode" ] ;
                    jsonschema:required "mode" ] ;
            td:name "setMode" ;
            td:title "setMode" ],
        [ a ex:SetCleaningAreaCommand,
                td:ActionAffordance ;
            td:hasForm [ http:methodName "POST" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:invokeAction ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home69/artifacts/vacuum_robot/set_cleaning_area> ] ;
            td:hasInputSchema [ a jsonschema:ObjectSchema ;
                    jsonschema:properties [ a jsonschema:StringSchema ;
                            jsonschema:propertyName "area" ] ;
                    jsonschema:required "area" ] ;
            td:name "setCleaningArea" ;
            td:title "setCleaningArea" ] ;
    td:hasPropertyAffordance [ a td:PropertyAffordance ;
            rdfs:comment "state of vacuum_robot" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home69/artifacts/vacuum_robot/properties/state> ] ;
            td:hasOutputSchema [ a jsonschema:StringSchema ;
                    jsonschema:enum "off",
                        "on" ] ;
            td:isObservable true ;
            td:name "state" ;
            td:title "state" ],
        [ a td:PropertyAffordance ;
            rdfs:comment "mode of vacuum_robot" ;
            td:hasForm [ http:methodName "GET" ;
                    hctl:forContentType "application/json" ;
                    hctl:hasOperationType td:readProperty ;
                    hctl:hasTarget <http://localhost:8080/workspaces/home69/artifacts/vacuum_robot/properties/mode> ] ;
            td:hasOutputSchema [ a jsonschema:StringSchema ;
